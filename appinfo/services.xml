<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
           http://symfony.com/schema/dic/services/services-1.0.xsd">

  <services>
    <service id="OCA\Journeys\Service\VideoRenderJobScheduler">
      <argument type="service" id="OCP\BackgroundJob\IJobList"/>
    </service>
    <service id="OCA\Journeys\Service\RenderedVideoLister">
      <argument type="service" id="OCP\Files\IRootFolder"/>
    </service>
    <service id="OCA\Journeys\Service\FacePresenceProvider">
      <argument type="service" id="OCP\IDBConnection"/>
    </service>
    <service id="OCA\Journeys\Service\ImageFetcher">
      <argument type="service" id="OCA\Journeys\Service\FacePresenceProvider"/>
      <argument type="service" id="OCP\IDBConnection"/>
    </service>
    <service id="OCA\Journeys\Service\Clusterer"/>
    <service id="OCA\Journeys\Service\ClusterMerger">
      <argument type="service" id="Psr\Log\LoggerInterface"/>
    </service>
    <service id="OCA\Journeys\Service\AlbumCreator"/>
    <service id="OCA\Journeys\Service\JournalService">
      <argument type="service" id="OCP\IDBConnection"/>
      <argument type="service" id="OCP\IUserManager"/>
      <argument type="service" id="OCP\IGroupManager"/>
      <argument type="service" id="OCP\Files\IRootFolder"/>
    </service>
    <service id="OCA\Journeys\Service\DiaryPhotoFetcher">
      <argument type="service" id="OCP\IDBConnection"/>
    </service>
    <service id="OCA\Journeys\Service\EntryLocationResolver">
      <argument type="service" id="OCA\Journeys\Service\ImageFetcher"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterLocationResolver"/>
    </service>
    <service id="OCA\Journeys\Service\PhotoPreviewResponder">
      <argument type="service" id="OCP\Files\IRootFolder"/>
      <argument type="service" id="OCP\IPreview"/>
    </service>
    <service id="OCA\Journeys\Service\StaticRouteMapService">
      <argument type="service" id="OCP\Files\AppData\IAppDataFactory"/>
      <argument type="service" id="OCP\Http\Client\IClientService"/>
      <argument type="service" id="OCP\IConfig"/>
      <argument type="service" id="Psr\Log\LoggerInterface"/>
    </service>
    <service id="OCA\Journeys\Service\CustomNameReassigner">
      <argument type="service" id="OCA\Journeys\Service\AlbumCreator"/>
      <argument type="service" id="Psr\Log\LoggerInterface"/>
    </service>
    <service id="OCA\Journeys\Service\VideoStorySelector"/>
    <service id="OCA\Journeys\Service\ClusterVideoImageProvider">
      <argument type="service" id="OCA\Journeys\Service\ImageFetcher"/>
      <argument type="service" id="OCA\Journeys\Service\Clusterer"/>
      <argument type="service" id="OCA\Journeys\Service\VideoStorySelector"/>
      <argument type="service" id="OCA\Journeys\Service\AlbumCreator"/>
      <argument type="service" id="OCP\IConfig"/>
    </service>
    <service id="OCA\Journeys\Service\ClusterVideoFilePreparer">
      <argument type="service" id="OCP\Files\IRootFolder"/>
    </service>
    <service id="OCA\Journeys\Service\ClusterVideoMusicProvider"/>
    <service id="OCA\Journeys\Service\ClusterVideoRenderer">
      <argument type="service" id="OCP\Files\IRootFolder"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterVideoMusicProvider"/>
    </service>
    <service id="OCA\Journeys\Service\ClusterVideoRendererLandscape">
      <argument type="service" id="OCP\Files\IRootFolder"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterVideoMusicProvider"/>
    </service>
    <service id="OCA\Journeys\Service\ClusterVideoJobRunner">
      <argument type="service" id="OCA\Journeys\Service\ClusterVideoImageProvider"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterVideoFilePreparer"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterVideoRenderer"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterVideoRendererLandscape"/>
      <argument type="service" id="OCP\IConfig"/>
      <argument type="service" id="OCA\Journeys\Service\VideoSubtitleResolver"/>
    </service>
    <service id="OCA\Journeys\Service\VideoSubtitleResolver">
      <argument type="service" id="OCA\Journeys\Service\SimplePlaceResolver"/>
    </service>
    <service id="OCA\Journeys\Service\HomeService">
      <argument type="service" id="OCP\IConfig"/>
      <argument type="service" id="OCA\Journeys\Service\HomeLocationDetector"/>
    </service>
    <service id="OCA\Journeys\Service\SimplePlaceResolver">
      <argument type="service" id="OCP\IDBConnection"/>
    </service>
    <service id="OCA\Journeys\Service\ClusterLocationResolver">
      <argument type="service" id="OCA\Journeys\Service\SimplePlaceResolver"/>
      <argument type="service" id="OCP\IDBConnection"/>
    </service>
    <service id="OCA\Journeys\Service\ClusteringManager">
      <argument type="service" id="OCA\Journeys\Service\ImageFetcher"/>
      <argument type="service" id="OCA\Journeys\Service\Clusterer"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterMerger"/>
      <argument type="service" id="OCA\Journeys\Service\AlbumCreator"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterLocationResolver"/>
      <argument type="service" id="OCA\Journeys\Service\HomeLocationDetector"/>
      <argument type="service" id="OCA\Journeys\Service\HomeService"/>
      <argument type="service" id="OCP\Notification\IManager"/>
      <argument type="service" id="Psr\Log\LoggerInterface"/>
      <argument type="service" id="OCP\IURLGenerator"/>
      <argument type="service" id="OCA\Journeys\Service\ClusterVideoJobRunner"/>
      <argument type="service" id="OCA\Journeys\Service\VideoRenderJobScheduler"/>
      <argument type="service" id="OCP\IConfig"/>
      <argument type="service" id="OCA\Journeys\Service\CustomNameReassigner"/>
    </service>
    <service id="OCA\Journeys\Controller\PersonalSettingsController">
      <argument>%app_id%</argument>
      <argument type="service" id="OCP\IRequest"/>
      <argument type="service" id="OCP\IUserSession"/>
      <argument type="service" id="OCA\Journeys\Service\ClusteringManager"/>
      <argument type="service" id="OCP\IConfig"/>
      <argument type="service" id="OCA\Journeys\Service\AlbumCreator"/>
      <argument type="service" id="OCA\Journeys\Service\VideoRenderJobScheduler"/>
      <argument type="service" id="OCA\Journeys\Service\RenderedVideoLister"/>
    </service>
    <service id="OCA\Journeys\Controller\PageController">
      <argument>%app_id%</argument>
      <argument type="service" id="OCP\IRequest"/>
    </service>
    <service id="OCA\Journeys\Controller\DiaryController">
      <argument>%app_id%</argument>
      <argument type="service" id="OCP\IRequest"/>
      <argument type="service" id="OCP\IUserSession"/>
      <argument type="service" id="OCA\Journeys\Service\JournalService"/>
      <argument type="service" id="OCA\Journeys\Service\DiaryPhotoFetcher"/>
      <argument type="service" id="OCA\Journeys\Service\EntryLocationResolver"/>
      <argument type="service" id="OCP\Security\ISecureRandom"/>
      <argument type="service" id="OCP\IURLGenerator"/>
      <argument type="service" id="OCP\IUserManager"/>
      <argument type="service" id="OCP\IGroupManager"/>
      <argument type="service" id="OCA\Journeys\Service\PhotoPreviewResponder"/>
      <argument type="service" id="OCP\IConfig"/>
    </service>
    <service id="OCA\Journeys\Controller\PublicDiaryController">
      <argument>%app_id%</argument>
      <argument type="service" id="OCP\IRequest"/>
      <argument type="service" id="OCA\Journeys\Service\JournalService"/>
      <argument type="service" id="OCA\Journeys\Service\PhotoPreviewResponder"/>
      <argument type="service" id="OCA\Journeys\Service\StaticRouteMapService"/>
      <argument type="service" id="OCP\IURLGenerator"/>
    </service>
  </services>
</container>
